# Surgical RL Configuration
# Copy this file to .env and fill in your values

# LLM Configuration for Scene Generation
# Supported providers: openai, anthropic, ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo-preview
# LLM_API_KEY=sk-...  # Uncomment and set your real API key
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# VLM Configuration for Visual Scene Generation
VLM_MODEL=gpt-4-vision-preview

# Ollama Configuration (for local models)
# Set LLM_PROVIDER=ollama to use local models
# Install Ollama from: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_VISION_MODEL=llava
OLLAMA_TIMEOUT=300

# Simulator Settings
DEFAULT_SIMULATOR=mujoco
MUJOCO_TIMESTEP=0.002
PYBULLET_TIMESTEP=0.004166667

# Rendering Settings
RENDER_WIDTH=640
RENDER_HEIGHT=480
RENDER_FPS=60

# RL Training Settings
RL_DEVICE=auto
RL_SEED=42
RL_TENSORBOARD_LOG=./logs/tensorboard

# Domain Randomization
RANDOMIZATION_ENABLED=false
PHYSICS_RANDOMIZATION=true
VISUAL_RANDOMIZATION=true
DYNAMICS_RANDOMIZATION=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=

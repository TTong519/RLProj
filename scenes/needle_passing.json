  "task": {
    "name": "needle_passing_task",
    "task_type": "needle_insertion",
    "description": "SURGEON passes the curved_passing_needle through tissue_target to ASSISTANT",
    "objectives": [
      {
        "name": "needle_pickup",
        "description": "SURGEON picks up the curved_passing_needle",
        "success_criteria": "Needle within 5mm of surgeon_arm end effector",
        "failure_criteria": null,
        "target_body": "curved_passing_needle",
        "weight": 1.0
      },
      {
        "name": "needle_pass",
        "description": "Drive the needle through tissue_target to ASSISTANT",
        "success_criteria": "Needle tip exits on the far side within 5mm of assistant_arm end effector",
        "failure_criteria": null,
        "target_body": "curved_passing_needle",
        "weight": 3.0
      },
      {
        "name": "assistant_receive",
        "description": "ASSISTANT receives the needle after pass-through",
        "success_criteria": "Assistant gripper closes on the needle within 2s of pass-through completion",
        "failure_criteria": null,
        "target_body": "needle_receiver_assistant",
        "weight": 2.0
      }
    ],
    "constraints": [
      {
        "name": "force_limit_surgeon",
        "type": "force",
        "target_entity": "surgeon_arm",
        "limits": [0.0, 10.0],
        "penalty_weight": 5.0
      },
      {
        "name": "force_limit_assistant",
        "type": "force",
        "target_entity": "assistant_arm",
        "limits": [0.0, 10.0],
        "penalty_weight": 5.0
      },
      {
        "name": "workspace_limit",
        "type": "position",
        "target_entity": "surgeon_arm",
        "limits": [-0.5, 0.5],
        "penalty_weight": 10.0
      }
    ],
    "reward_shaping": {
      "success_reward": 100.0,
      "failure_penalty": -100.0,
      "time_penalty": -0.01,
      "distance_reward_scale": 1.0,
      "constraint_violation_penalty": -1.0,
      "collision_penalty": -10.0,
      "tissue_damage_penalty": -50.0
    },
    "max_episode_length": 1000,
    "time_limit": 120.0
  },
  "domain_randomization": {
    "physics": {
      "enabled": true,
      "mass_range": [0.9, 1.1],
      "friction_range": [0.4, 0.6],
      "stiffness_range": [0.9, 1.1]
    },
    "visual": {
      "enabled": true,
      "color_range": [0.9, 1.1],
      "lighting_variation": [0.8, 1.2]
    },
    "dynamics": {"enabled": false},
    "randomize_each_episode": true,
    "seed": 42
  },
  "multi_agent": {
    "arm_configs": [
      {
        "role": "surgeon",
        "robot_ref": "surgeon_arm",
        "observation_keys": ["joint_positions", "end_effector_pos", "target_pos", "distance_to_target"]
      },
      {
        "role": "assistant",
        "robot_ref": "assistant_arm",
        "observation_keys": ["joint_positions", "end_effector_pos", "target_pos", "distance_to_target"]
      }
    ],
    "shared_policy": true,
    "cooperative": true,
    "observation_sharing": true
  },
  "simulator": "mujoco",
  "dreamer": {

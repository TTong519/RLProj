  "task": {
    "name": "multi_stage_suturing",
    "description": "Pick up a needle and suture two skin patches together",
    "objectives": [
      {
        "name": "needle_approach",
        "description": "Approach the surgical needle with the needle driver",
        "success_criteria": "End effector within 0.02m of needle",
        "weight": 0.5
      },
      {
        "name": "needle_pickup",
        "description": "Grasp and lift the surgical needle",
        "success_criteria": "Needle grasped and lifted above tissue",
        "weight": 1.0
      },
      {
        "name": "tissue_penetration",
        "description": "Drive the needle through both skin patches",
        "success_criteria": "Needle passes through left and right tissue",
        "weight": 2.0
      },
      {
        "name": "suture_completion",
        "description": "Complete the suture connecting both patches",
        "success_criteria": "Suture holds both patches together",
        "weight": 3.0
      }
    ],
    "constraints": [
      {
        "name": "force_limit",
        "type": "force",
        "target_entity": "surgical_arm_1",
        "limits": [0.0, 5.0],
        "penalty_weight": 5.0
      },
      {
        "name": "workspace_limit",
        "type": "position",
        "target_entity": "surgical_arm_1",
        "limits": [-0.5, 0.5],
        "penalty_weight": 10.0
      }
    ],
